{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Beacon",
  "version": "../package.json",
  "identifier": "com.beacon.cc",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "settings",
        "title": "Beacon — Settings",
        "width": 460,
        "height": 560,
        "resizable": true,
        "visible": false,
        "focus": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Status indicator for Claude Code sessions",
    "longDescription": "Beacon is a lightweight menu-bar / system-tray status indicator for Claude Code. A traffic-light icon shows whether any session needs you, is working, or is ready, and a floating always-on-top widget breaks it down per session. Detection is fully local — Claude Code hooks POST to a loopback-only listener; no telemetry, no network egress.",
    "copyright": "© 2026 Beacon",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
