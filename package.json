{
  "name": "cc-beacon",
  "private": true,
  "version": "0.3.0",
  "description": "Session Signals — a lightweight, fully-local desktop status indicator for Claude Code.",
  "license": "MIT",
  "author": "Session Signals contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/earsenio/session-signals.git"
  },
  "homepage": "https://github.com/earsenio/session-signals#readme",
  "bugs": {
    "url": "https://github.com/earsenio/session-signals/issues"
  },
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "version": "node scripts/sync-version.mjs && cargo update --manifest-path src-tauri/Cargo.toml -p cc-beacon --quiet && git add package.json src-tauri/Cargo.toml src-tauri/Cargo.lock",
    "postversion": "git push --follow-tags",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major"
  },
  "dependencies": {
    "@fontsource/geist-mono": "^5.2.8",
    "@fontsource/geist-sans": "^5.2.5",
    "@tauri-apps/api": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.0"
  }
}
